Content-Type: application/json

{
  "firstName": "Carlos",
  "lastName": "Martinez",
  "email": "carlos@example.com",
  "phone": "555-555-1234",
  "address": "456 Oak Ave, Provo, UT 84601",
  "company": "Tech Corp",
  "notes": "Met at BYU-Idaho event"
}

