{
  "swagger": "2.0",
  "info": {
    "title": "Pantry Tracker API",
    "description": "Track pantry items, costs, and expiration dates",
    "version": "1.0.0"
  },
  "host": "chase-pope-341.onrender.com",
  "basePath": "/",
  "schemes": [
    "https"
  ],
  "paths": {
    "/items/": {
      "get": {
        "description": "Retrieve all pantry items from the database.",
        "responses": {
          "200": {
            "description": "OK"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "post": {
        "description": "",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "description": "New pantry item details",
            "schema": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "example": "Chicken Broth"
                },
                "category": {
                  "type": "string",
                  "example": "Canned Goods"
                },
                "quantity": {
                  "type": "number",
                  "example": 2
                },
                "cost": {
                  "type": "number",
                  "example": 1.99
                },
                "expirationDate": {
                  "type": "string",
                  "example": "2027-03-15"
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/items/{id}": {
      "get": {
        "description": "Retrieve a single pantry item by its unique database ID.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "The MongoDB ObjectId of the pantry item"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "put": {
        "description": "Update an existing pantry item by its ID.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "The MongoDB ObjectId of the item to update"
          },
          {
            "name": "body",
            "in": "body",
            "description": "Updated pantry item properties",
            "schema": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "example": "Chicken Broth"
                },
                "category": {
                  "type": "string",
                  "example": "Canned Goods"
                },
                "quantity": {
                  "type": "number",
                  "example": 5
                },
                "cost": {
                  "type": "number",
                  "example": 1.99
                },
                "expirationDate": {
                  "type": "string",
                  "example": "2027-03-15"
                }
              }
            }
          }
        ],
        "responses": {
          "204": {
            "description": "No Content"
          },
          "400": {
            "description": "Bad Request"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "delete": {
        "description": "Delete a pantry item from the database.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "The MongoDB ObjectId of the item to delete"
          }
        ],
        "responses": {
          "204": {
            "description": "No Content"
          },
          "400": {
            "description": "Bad Request"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    }
  }
}