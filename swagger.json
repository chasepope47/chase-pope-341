  "definitions": {
    "Item": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "example": "Chicken Broth"
        },
        "category": {
          "type": "string",
          "example": "Canned Goods"
        },
        "quantity": {
          "type": "number",
          "example": 2
        },
        "cost": {
          "type": "number",
          "example": 1.99
        },
        "expirationDate": {
          "type": "string",
          "example": "2027-03-15"
        }
      }
    },
    "Note": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "example": "Restock reminder"
        },
        "body": {
          "type": "string",
          "example": "Need to buy more chicken broth before the holidays"
        },
        "category": {
          "type": "string",
          "example": "shopping"
        },
        "priority": {
          "type": "string",
          "example": "high"
        },
        "itemId": {
          "type": "string",
          "example": "665f1a2b3c4d5e6f7a8b9c0d"
        },
        "dueDate": {
          "type": "string",
          "example": "2025-12-31"
        },
        "completed": {
          "type": "boolean",
          "example": false
        }
      }
