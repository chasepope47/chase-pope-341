{
  "swagger": "2.0",
  "info": {
    "title": "Pantry Tracker API",
    "description": "Track pantry items and notes. Write routes require GitHub OAuth login — visit /auth/github to authenticate, then return here to test protected routes.",
    "version": "1.0.0"
  },
  "host": "chase-pope-341.onrender.com",
  "basePath": "/",
  "schemes": [
    "https"
  ],
  "securityDefinitions": {
    "githubOAuth": {
      "type": "oauth2",
      "authorizationUrl": "https://github.com/login/oauth/authorize",
      "flow": "implicit",
      "scopes": {
        "user:email": "Read user email"
      }
    }
  },
  "paths": {
    "/auth/github": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "Login with GitHub",
        "description": "Redirects to GitHub OAuth login page. After authorizing, GitHub will redirect back to /auth/github/callback and you will be logged in.",
        "responses": {
          "302": {
            "description": "Redirect to GitHub login"
          },
          "503": {
            "description": "Service Unavailable"
          }
        }
      }
    },
    "/auth/profile": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "Get current logged-in user",
        "description": "Returns the GitHub profile of the currently logged-in user. Returns 401 if not logged in.",
        "responses": {
          "200": {
            "description": "User profile"
          },
          "401": {
            "description": "Not logged in"
          }
        }
      }
    },
    "/auth/logout": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "Logout",
        "description": "Destroys the current session and logs the user out.",
        "responses": {
          "200": {
            "description": "Logged out successfully"
          }
        }
      }
    },
    "/items/": {
      "get": {
        "tags": [
          "Items"
        ],
        "summary": "Get all pantry items",
        "description": "Returns a list of all items in the pantry. No authentication required.",
        "responses": {
          "200": {
            "description": "List of pantry items"
          },
          "500": {
            "description": "Server error"
          }
        }
      },
      "post": {
        "tags": [
          "Items"
        ],
        "summary": "Create a pantry item (login required)",
        "description": "Creates a new pantry item. Must be logged in via GitHub OAuth (/auth/github).",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "description": "New pantry item details",
            "schema": {
              "$ref": "#/definitions/Item"
            },
            "required": true
          }
        ],
        "responses": {
          "201": {
            "description": "Item created, returns new item ID"
          },
          "400": {
            "description": "Validation error"
          },
          "401": {
            "description": "Not authenticated - visit /auth/github first"
          },
          "500": {
            "description": "Server error"
          }
        },
        "security": [
          {
            "githubOAuth": [
              "user:email"
            ]
          }
        ]
      }
    },
    "/items/{id}": {
      "get": {
        "tags": [
          "Items"
        ],
        "summary": "Get a single pantry item",
        "description": "Returns one pantry item by its MongoDB ID. No authentication required.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "MongoDB ObjectId of the item"
          }
        ],
        "responses": {
          "200": {
            "description": "Pantry item found"
          },
          "400": {
            "description": "Invalid ID format"
          },
          "404": {
            "description": "Item not found"
          },
          "500": {
            "description": "Server error"
          }
        }
      },
      "put": {
        "tags": [
          "Items"
        ],
        "summary": "Update a pantry item (login required)",
        "description": "Updates an existing pantry item by ID. Must be logged in via GitHub OAuth (/auth/github).",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "MongoDB ObjectId of the item"
          },
          {
            "name": "body",
            "in": "body",
            "description": "Updated pantry item properties",
            "schema": {
              "$ref": "#/definitions/Item"
            },
            "required": true
          }
        ],
        "responses": {
          "204": {
            "description": "Item updated successfully"
          },
          "400": {
            "description": "Validation error or invalid ID"
          },
          "401": {
            "description": "Not authenticated - visit /auth/github first"
          },
          "404": {
            "description": "Item not found"
          },
          "500": {
            "description": "Server error"
          }
        },
        "security": [
          {
            "githubOAuth": [
              "user:email"
            ]
          }
        ]
      },
      "delete": {
        "tags": [
          "Items"
        ],
        "summary": "Delete a pantry item (login required)",
        "description": "Deletes a pantry item by ID. Must be logged in via GitHub OAuth (/auth/github).",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "MongoDB ObjectId of the item"
          }
        ],
        "responses": {
          "200": {
            "description": "Item deleted successfully"
          },
          "400": {
            "description": "Invalid ID format"
          },
          "401": {
            "description": "Not authenticated - visit /auth/github first"
          },
          "404": {
            "description": "Item not found"
          },
          "500": {
            "description": "Server error"
          }
        },
        "security": [
          {
            "githubOAuth": [
              "user:email"
            ]
          }
        ]
      }
    },
    "/notes/": {
      "get": {
        "tags": [
          "Notes"
        ],
        "summary": "Get all notes",
        "description": "Returns a list of all notes. No authentication required.",
        "responses": {
          "200": {
            "description": "List of notes"
          },
          "500": {
            "description": "Server error"
          }
        }
      },
      "post": {
        "tags": [
          "Notes"
        ],
        "summary": "Create a note (login required)",
        "description": "Creates a new note. Must be logged in via GitHub OAuth (/auth/github).",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/Note"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Note created, returns new note ID"
          },
          "400": {
            "description": "Validation error"
          },
          "401": {
            "description": "Not authenticated - visit /auth/github first"
          },
          "500": {
            "description": "Server error"
          }
        },
        "security": [
          {
            "githubOAuth": [
              "user:email"
            ]
          }
        ]
      }
    },
    "/notes/{id}": {
      "get": {
        "tags": [
          "Notes"
        ],
        "summary": "Get a single note",
        "description": "Returns one note by its MongoDB ID. No authentication required.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "MongoDB ObjectId of the note"
          }
        ],
        "responses": {
          "200": {
            "description": "Note found"
          },
          "400": {
            "description": "Invalid ID format"
          },
          "404": {
            "description": "Note not found"
          },
          "500": {
            "description": "Server error"
          }
        }
      },
      "put": {
        "tags": [
          "Notes"
        ],
        "summary": "Update a note (login required)",
        "description": "Updates an existing note by ID. Must be logged in via GitHub OAuth (/auth/github).",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "MongoDB ObjectId of the note"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/Note"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Note updated successfully"
          },
          "400": {
            "description": "Validation error or invalid ID"
          },
          "401": {
            "description": "Not authenticated - visit /auth/github first"
          },
          "404": {
            "description": "Note not found"
          },
          "500": {
            "description": "Server error"
          }
        },
        "security": [
          {
            "githubOAuth": [
              "user:email"
            ]
          }
        ]
      },
      "delete": {
        "tags": [
          "Notes"
        ],
        "summary": "Delete a note (login required)",
        "description": "Deletes a note by ID. Must be logged in via GitHub OAuth (/auth/github).",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "MongoDB ObjectId of the note"
          }
        ],
        "responses": {
          "200": {
            "description": "Note deleted successfully"
          },
          "400": {
            "description": "Invalid ID format"
          },
          "401": {
            "description": "Not authenticated - visit /auth/github first"
          },
          "404": {
            "description": "Note not found"
          },
          "500": {
            "description": "Server error"
          }
        },
        "security": [
          {
            "githubOAuth": [
              "user:email"
            ]
          }
        ]
      }
    }
  },
  "definitions": {
    "Item": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "example": "Chicken Broth"
        },
        "category": {
          "type": "string",
          "example": "Canned Goods"
        },
        "quantity": {
          "type": "number",
          "example": 2
        },
        "cost": {
          "type": "number",
          "example": 1.99
        },
        "expirationDate": {
          "type": "string",
          "example": "2027-03-15"
        }
      }
    },
    "Note": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "example": "Restock reminder"
        },
        "body": {
          "type": "string",
          "example": "Need to buy more chicken broth before the holidays"
        },
        "category": {
          "type": "string",
          "example": "shopping"
        },
        "priority": {
          "type": "string",
          "example": "high"
        },
        "itemId": {
          "type": "string",
          "example": ""
        },
        "dueDate": {
          "type": "string",
          "example": "2025-12-31"
        },
        "completed": {
          "type": "boolean",
          "example": false
        }
      }
    }
  }
}